:223,"twoPersons":224},{"text":226,"url":227},[160,229,230,231,232,233],{"name":235,"description":236,"price":270,"bookingLink":271,"photos":272},{"onePerson":223,"twoPersons":224},{"text":226,"url":227},[240,241,162,242,243,244,245,246],{"name":248,"description":249,"price":274,"bookingLink":275,"photos":276},{"onePerson":251,"twoPersons":252},{"text":226,"url":227},[161,255,256,257,258,259,260,261,262],"/sk/pages/accommodation",{"title":132},"sk/pages/accommodation","Hfol6wa4YRBvR_uHstCniqgxMZv7VoBkpJcW9ux8eJ8",{"id":282,"title":137,"body":283,"description":284,"extension":14,"meta":309,"navigation":17,"path":320,"seo":321,"stem":322,"__hash__":323},"content/sk/pages/restaurant.json",{"id":10,"title":137,"description":284,"photos":285,"openingHoursTitle":30,"openingHours":289,"menuTitle":299,"menu":300},"Penzión Turzov disponuje v prízemnej časti objektu reštauračnou časťou, kde sa návštevníci môžu občerstviť a vychutnať si výborné pivo, lahodnú kávu či vybrať si z ponuky hotových jedál. V prípade priaznivého počasia je tiež k dispozícii na sedenie aj terasa a zastrešený prístrešok v exteriéri. Okrem bežnej ponuky vie pre záujemcov náš personál zabezpečiť a pripraviť aj rodinné oslavy, či firemné posedenia.",[286,287,288],"restaurant/restauracia_altanok.jpg","restaurant/restauracia_doska.png","restaurant/restauracia_salonik.png",[290,292,293,294,295,297,298],{"day":34,"fromTo":291},"10:00 - 20:00",{"day":37,"fromTo":291},{"day":39,"fromTo":291},{"day":41,"fromTo":291},{"day":43,"fromTo":296},"10:00 - 21:00",{"day":45,"fromTo":296},{"day":47,"fromTo":291},"Naša ponuka",[301,302,303,304,305,306,307,308],"/restaurant/menu/Menu_1.jpg","/restaurant/menu/Menu_2.jpg","/restaurant/menu/Menu_3.jpg","/restaurant/menu/Menu_4.jpg","/restaurant/menu/Menu_5.jpg","/restaurant/menu/Menu_6.jpg","/restaurant/menu/Menu_7.jpg","/restaurant/menu/Menu_8.jpg",{"photos":310,"openingHoursTitle":30,"openingHours":311,"menuTitle":299,"menu":319},[286,287,288],[312,313,314,315,316,317,318],{"day":34,"fromTo":291},{"day":37,"fromTo":291},{"day":39,"fromTo":291},{"day":41,"fromTo":291},{"day":43,"fromTo":296},{"day":45,"fromTo":296},{"day":47,"fromTo":291},[301,302,303,304,305,306,307,308],"/sk/pages/restaurant",{"title":137,"description":284},"sk/pages/restaurant","_oA6B3l-L3FiXie9NodUa0KVdLzvxtlxpYGFhHnU6rQ",{"id":23,"title":24,"body":325,"description":26,"extension":14,"meta":344,"navigation":17,"path":93,"seo":363,"stem":95,"__hash__":96},{"id":11,"title":24,"description":26,"photos":326,"openingHoursTitle":30,"openingHoursInfo":31,"openingHours":327,"priceListTitle":48,"priceList":335},[28,29],[328,329,330,331,332,333,334],{"day":34,"fromTo":35},{"day":37,"fromTo":35},{"day":39,"fromTo":35},{"day":41,"fromTo":35},{"day":43,"fromTo":35},{"day":45,"fromTo":35},{"day":47,"fromTo":35},[336,337,338,339,340,341,342,343],{"name":51,"price":52},{"name":54,"price":55},{"name":57,"price":58},{"name":60,"price":61},{"name":63,"price":64},{"name":66,"price":67},{"name":69,"price":70},{"name":72,"price":73},{"photos":345,"openingHoursTitle":30,"openingHoursInfo":31,"openingHours":346,"priceListTitle":48,"priceList":354},[28,29],[347,348,349,350,351,352,353],{"day":34,"fromTo":35},{"day":37,"fromTo":35},{"day":39,"fromTo":35},{"day":41,"fromTo":35},{"day":43,"fromTo":35},{"day":45,"fromTo":35},{"day":47,"fromTo":35},[355,356,357,358,359,360,361,362],{"name":51,"price":52},{"name":54,"price":55},{"name":57,"price":58},{"name":60,"price":61},{"name":63,"price":64},{"name":66,"price":67},{"name":69,"price":70},{"name":72,"price":73},{"title":24,"description":26},{"id":365,"title":152,"body":366,"description":367,"extension":14,"meta":407,"navigation":17,"path":425,"seo":426,"stem":427,"__hash__":428},"content/sk/pages/turzovia.json",{"id":12,"title":152,"description":367,"photos":368,"openingHoursTitle":30,"openingHoursInfo":374,"openingHours":375,"priceListTitle":48,"priceList":383,"rules":396,"info":400},"Nápad vybudovať v lokalite lanovú dráhu sa zrodil už na jeseň 2023. Z toho dôvodu sa Sociálny podnik Mesta Gelnica ako prevádzkovateľ Penziónu Turzov v roku 2024 zapojil do výzvy vyhlásenej Košickým samosprávny krajom z programu Terra Incognita na podporu cestovného ruchu. Projekt bol v rámci vyhlásenej výzvy úspešný, pričom Košický samosprávny kraj poskytol na jeho realizáciu dotáciu vo výške 45 000€, zvyšné finančné prostriedky vo výške asi 10 000€ boli poskytnuté z rozpočtu Mesta Gelnica. Zámerom projektu bolo vybudovanie nového športovo- rekreačného areálu a tým zvýšenie atraktívnosti ubytovania v penzióne Turzov a celkové zatraktívnenie prímestskej lokality Turzov. Areál lanového parku pozostáva z troch častí: 1. trenažér, 2. vysoké prekážky s rôznymi stupňami náročnosti+ zip-line, 3. nízke prekážky. Keďže bezpečnosť je pre nás prvoradá, každý záujemca bude pri prekonávaní vysokých prekážok istnený pomocou špičkovej horolezeckej výstroje- unikátnym systémom Clic-IT, ktorý vylúči možnosť pádu. Lanový park TurzoVIA bude v prevádzke spravidla od apríla do októbra, v závislosti od počasia, počas letných prázdnin denne, mimo hlavnej sezóny na objednávku.",[369,370,371,372,373],"turzovia/TurzoVIA1.jpg","turzovia/TurzoVIA2.jpg","turzovia/TurzoVIA3.jpg","turzovia/TurzoVIA4.jpg","turzovia/TURZOVIA_nizkeprekazky.jpg","TurzoVia je otvorená v mesiacoch apríl až september v závislosti od počasia. V prípade záujmu o rezerváciu nás prosím kontaktujte vopred.",[376,377,378,379,380,381,382],{"day":34,"fromTo":35},{"day":37,"fromTo":35},{"day":39,"fromTo":35},{"day":41,"fromTo":35},{"day":43,"fromTo":35},{"day":45,"fromTo":35},{"day":47,"fromTo":35},[384,387,390,393],{"name":385,"price":386},"Jednorázový vstup","7€",{"name":388,"price":389},"Opakovaný vstup (2 vstupy po sebe)","12€",{"name":391,"price":392},"Permanentka (5 vstupov)","30€",{"name":394,"price":395},"Permanentka (10 vstupov)","50€",{"url":397,"title":398,"label":399},"turzovia/rules.pdf","Prevádzkový poriadok","Stiahnúť",{"ksk":401,"text":402,"krt":406},"turzovia/info/ksk.