[{"data":1,"prerenderedAt":464},["ShallowReactive",2],{"headerApp":3,"$3PdRvnAoUU":22,"footerApp":97,"$7-aPZDhIOI":118,"$RPHmXkNkLF":215,"$3xLjjpvES-":281,"$UZ9DIFb-CC":324,"$yjelg46sKB":364,"$f8xXRRsLA-":429},{"id":4,"title":5,"body":6,"description":13,"extension":14,"meta":15,"navigation":17,"path":18,"seo":19,"stem":20,"__hash__":21},"content/sk/layout/header-app.json","Header App",{"logo":7,"pagesInMenu":8},"",[9,10,11,12],"accommodation","restaurant","terrace","turzovia",null,"json",{"logo":7,"pagesInMenu":16},[9,10,11,12],true,"/sk/layout/header-app",{"title":5},"sk/layout/header-app","qzSkIjbCYFob3XMOCujRd7w6ZpdVWFw04k6UGMAeEtY",{"id":23,"title":24,"body":25,"description":26,"extension":14,"meta":74,"navigation":17,"path":93,"seo":94,"stem":95,"__hash__":96},"content/sk/pages/terrace.json","Terasa a požičovňa",{"id":11,"title":24,"description":26,"photos":27,"openingHoursTitle":30,"openingHoursInfo":31,"openingHours":32,"priceListTitle":48,"priceList":49},"Areál bývalých turzovských kúpeľov (cca 10min.od penziónu)  poskytuje návštevníkom možnosť vyžitia pri vode, kde podnik v letnej sezóne prevádzkuje bufet s občerstvením. Samozrejmosťou v ponuke sú chladené čapované nápoje, káva, pochutiny a nanuky. V letnej sezóne 2024  na tomto mieste pribudla aj požičovňa lehátok, paddleboardov a ďalšieho športového vybavenia.",[28,29],"terrace/bufet_pozicovna.jpg","terrace/bufet_pozicovna_2.jpg","Otváracie hodiny","Terasa a bufet pri hornom jazere je otvorená počas letných mesiacov (jún - september).",[33,36,38,40,42,44,46],{"day":34,"fromTo":35},"Pondelok","11:00 - 17:00",{"day":37,"fromTo":35},"Utorok",{"day":39,"fromTo":35},"Streda",{"day":41,"fromTo":35},"Štvrtok",{"day":43,"fromTo":35},"Piatok",{"day":45,"fromTo":35},"Sobota",{"day":47,"fromTo":35},"Nedeľa","Cenník",[50,53,56,59,62,65,68,71],{"name":51,"price":52},"Lehátko plastové","2€/deň",{"name":54,"price":55},"Lehátko hliníkové so strieškou","3€/deň",{"name":57,"price":58},"Stolík ","1€/deň",{"name":60,"price":61},"Set lehátok (2x lehátko + stolík)","4€/deň",{"name":63,"price":64},"Paddleboard s príslušenstvom - malý","4€/hod",{"name":66,"price":67},"Paddleboard s príslušenstvom - veľký","5€/hod",{"name":69,"price":70},"Záchranná vesta","1€/hod",{"name":72,"price":73},"Športové náčinie (frisby, set na bedminton)","2€/hod",{"photos":75,"openingHoursTitle":30,"openingHoursInfo":31,"openingHours":76,"priceListTitle":48,"priceList":84},[28,29],[77,78,79,80,81,82,83],{"day":34,"fromTo":35},{"day":37,"fromTo":35},{"day":39,"fromTo":35},{"day":41,"fromTo":35},{"day":43,"fromTo":35},{"day":45,"fromTo":35},{"day":47,"fromTo":35},[85,86,87,88,89,90,91,92],{"name":51,"price":52},{"name":54,"price":55},{"name":57,"price":58},{"name":60,"price":61},{"name":63,"price":64},{"name":66,"price":67},{"name":69,"price":70},{"name":72,"price":73},"/sk/pages/terrace",{"title":24,"description":26},"sk/pages/terrace","oHHmARMlTg2EI7ocXgjcubp00TuUna5clZPQDSBiqkQ",{"id":98,"title":99,"body":100,"description":13,"extension":14,"meta":111,"navigation":17,"path":114,"seo":115,"stem":116,"__hash__":117},"content/sk/layout/footer-app.json","Kontakt",{"id":101,"title":99,"phone":102,"email":103,"facebook":104,"address":107,"map":108},"footerApp","+421 919 491 157, +421 948 522 335","info@spmgl.sk",{"title":105,"href":106},"Turzov","https://www.facebook.com/profile.php?id=61552047947591","Penzión Turzov, Thurzovská 1822, Gelnica",{"width":109,"height":110},"50%","400",{"phone":102,"email":103,"facebook":112,"address":107,"map":113},{"title":105,"href":106},{"width":109,"height":110},"/sk/layout/footer-app",{"title":99},"sk/layout/footer-app","nTKmMesLr6_YArW7OVN65JTJ8V3hOnRX6-nA2rdfHAE",{"id":119,"title":120,"body":121,"description":13,"extension":14,"meta":181,"navigation":17,"path":211,"seo":212,"stem":213,"__hash__":214},"content/sk/pages/home.json","Domov",{"id":122,"title":120,"carousel":123,"sections":155},"index",{"autoplayInterval":124,"slides":125},0,[126,130,135,140,144,150],{"active":17,"photo":127,"title":128,"description":129},"home/carousel/info.jpg","Oznam","Penzión Turzov bude dnes z prevádzkových dôvodov zatvorený.",{"active":17,"photo":131,"title":132,"description":133,"link":134},"home/carousel/accommodation.jpg","Ubytovanie","Penzión Turzov sa nachádza v rekreačnej lokalite Turzov, približne 2 km od centra mesta Gelnica a len na skok od areálu bývalých Turzovských kúpeľov. Penzión sa nachádza pri spodnom Turzovskom jazere, obklopený čarokrásnou prírodou, ktorá ponúka nespočetné možnosti pre relax, rekreačnú turistiku ale aj pre náročnejších turistov. Návštevníkom je penzión k dispozícii celoročne.",{"text":132,"page":9},{"active":17,"photo":136,"title":137,"description":138,"link":139},"home/carousel/restaurant.jpg","Reštaurácia","Penzión Turzov disponuje reštauračnou časťou, kde sa návštevníci môžu občerstviť a vychutnať si výborné pivo, lahodnú kávu či vybrať si z ponuky hotových jedál. V prípade priaznivého počasia je tiež k dispozícii na sedenie aj terasa. V tesnej blízkosti penziónu sa nachádza niekoľko altánkov a ohnísk vhodných na opekanie.",{"text":137,"page":10},{"active":17,"photo":141,"title":24,"description":142,"link":143},"home/carousel/terrace.jpg","Počas letnej sezóny tiež prevádzkujeme pre návštevníkov pri hornom turzovskom jazere bufet s občerstvením (približne 10 min.od penziónu), kde v sezóne roku 2024 pribudla aj možnosť zapožičať si lehátka, paddleboardy a ďalšie športové vybavenie.",{"text":24,"page":11},{"active":17,"photo":145,"title":146,"description":147,"link":148},"home/carousel/tips.jpg","Tipy na výlety","Návštevníci si v rámci oddychu môžu vychutnať pohľad na nádhernú okolitú prírodu alebo navštíviť neďaleký Banský skanzen a Štôlňu Jozef. Okolie poskytuje nemálo možností na nenáročné aj dlhšie a náročnejšie vychádzky a cyklotúry. Okolité tajchy tiež vytvárajú vhodné podmienky pre nadšencov rybolovu. ",{"text":146,"page":149},"tips",{"active":17,"photo":151,"title":152,"description":153,"link":154},"https://dynamic-media-cdn.tripadvisor.com/media/photo-o/2b/56/71/59/atmosphere.jpg","TurzoVia","V lete 2025 pribudne v bezprostrednej blízkosti penziónu unikátna lanová dráha TurzoVia. Lanový park s celkovou dĺžkou viac ako 110m umiestnený na živých stromoch poskytne nezabudnuteľné adrenalínové zážitky pre malých aj veľkých.",{"text":152,"page":12},[156,163,166,170,175],{"active":17,"title":132,"description":157,"link":158,"photos":159},"Commonly used in graphic design, publishing, and web development. Its purpose is to permit a page layout to be designed, independently of the copy that will subsequently populate it, or to demonstrate various fonts of a typeface without meaningful text that could be distracting.",{"text":132,"page":9},[160,161,162],"accommodation/Izba_1_3-min.jpg","accommodation/Izba_3_3-min.jpg","accommodation/Izba_2_4-min.jpg",{"active":17,"title":137,"description":157,"link":164,"photos":165},{"text":137,"page":10},[151,151,151],{"active":17,"title":24,"description":157,"link":167,"photos":168},{"text":24,"page":11},[169,169,169],"https://static.vecteezy.com/system/resources/previews/011/236/240/non_2x/on-a-lake-in-sweden-in-smalland-water-lily-field-blue-water-sunny-sky-forests-photo.jpg",{"active":17,"title":171,"description":157,"link":172,"photos":173},"TurzoVIA",{"text":171,"page":12},[174,174,174],"https://slovenskycestovatel.sk/images/items/1693/tarzania-kubinska-hola96102524.jpg",{"active":176,"title":177,"description":157,"link":178,"photos":179},false,"Tipy na výlet",{"text":177,"page":149},[180,180,180],"https://images.photowall.com/products/73393/perfect-beach.jpg?h=699&q=85",{"carousel":182,"sections":195},{"autoplayInterval":124,"slides":183},[184,185,187,189,191,193],{"active":17,"photo":127,"title":128,"description":129},{"active":17,"photo":131,"title":132,"description":133,"link":186},{"text":132,"page":9},{"active":17,"photo":136,"title":137,"description":138,"link":188},{"text":137,"page":10},{"active":17,"photo":141,"title":24,"description":142,"link":190},{"text":24,"page":11},{"active":17,"photo":145,"title":146,"description":147,"link":192},{"text":146,"page":149},{"active":17,"photo":151,"title":152,"description":153,"link":194},{"text":152,"page":12},[196,199,202,205,208],{"active":17,"title":132,"description":157,"link":197,"photos":198},{"text":132,"page":9},[160,161,162],{"active":17,"title":137,"description":157,"link":200,"photos":201},{"text":137,"page":10},[151,151,151],{"active":17,"title":24,"description":157,"link":203,"photos":204},{"text":24,"page":11},[169,169,169],{"active":17,"title":171,"description":157,"link":206,"photos":207},{"text":171,"page":12},[174,174,174],{"active":176,"title":177,"description":157,"link":209,"photos":210},{"text":177,"page":149},[180,180,180],"/sk/pages/home",{"title":120},"sk/pages/home","f3QF_kRR3WtYVBs-1nL8FlpzusW3ibJmY2JQBzpPPkE",{"id":216,"title":132,"body":217,"description":13,"extension":14,"meta":263,"navigation":17,"path":277,"seo":278,"stem":279,"__hash__":280},"content/sk/pages/accommodation.json",{"id":9,"title":132,"rooms":218},[219,234,247],{"name":220,"description":221,"price":222,"bookingLink":225,"photos":228},"Izba Economy #1","Izba so zariadením na osobnú hygienu (WC, umývadlo, sprchový kút) a balkónom. Izba je vybavená posteľami, nočnými stolíkmi s nočnými lampami, skriňou s ramienkami, komodou a televízorom. Súčasťou izby je tiež chladnička, varná kanvica, šálky, tanieriky, príbor a nádoba na odpadky. V prípade potreby je izbu možné dovybaviť prístelkou alebo detskou postieľkou v cene 15€/noc.",{"onePerson":223,"twoPersons":224},"35","55",{"text":226,"url":227},"Booking","https://www.booking.com/hotel/sk/penzion-turzov-gelnica.sk.html?label=gen173nr-1BCAEoggI46AdIM1gEaM0BiAEBmAEiuAEXyAEM2AEB6AEBiAIBqAIDuAKX_L7ABsACAdICJDAwNmE4ODA2LWY4OGEtNDFmMy1hYTQyLWM1YTlkNGQ4Y2YwMdgCBeACAQ&sid=bd1edb9bf1a9487e235fd063450aec0a&aid=304142&ucfs=1&arphpl=1",[160,229,230,231,232,233],"accommodation/Izba_1_1-min.jpg","accommodation/Izba_1_5-min.jpg","ac