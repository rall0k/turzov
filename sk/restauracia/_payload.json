32,"fromTo":33},{"day":35,"fromTo":33},{"day":37,"fromTo":33},{"day":39,"fromTo":33},{"day":41,"fromTo":33},{"day":43,"fromTo":33},{"day":45,"fromTo":33},[48,49,50,51,52,53,54,55],"/sk/pages/restaurant",{"title":24,"description":26},"sk/pages/restaurant","rEQy_9xov44T8bjNPMZvXocZrsZgX1t568IwMaqSep4",{"id":72,"title":73,"body":74,"description":13,"extension":14,"meta":85,"navigation":17,"path":88,"seo":89,"stem":90,"__hash__":91},"content/sk/layout/footer-app.json","Kontakt",{"id":75,"title":73,"phone":76,"email":77,"facebook":78,"address":81,"map":82},"footerApp","+421 919 491 158","info@spmgl.sk",{"title":79,"href":80},"Turzov","https://www.facebook.com/profile.php?id=61552047947591","Penzión Turzov, Thurzovská 1822, Gelnica",{"width":83,"height":84},"50%","400",{"phone":76,"email":77,"facebook":86,"address":81,"map":87},{"title":79,"href":80},{"width":83,"height":84},"/sk/layout/footer-app",{"title":73},"sk/layout/footer-app","GOyFvRtnONGW0dRwDhU6Irr5YU-PSR5F1INEt3xp6qo",{"id":93,"title":94,"body":95,"description":13,"extension":14,"meta":146,"navigation":17,"path":175,"seo":176,"stem":177,"__hash__":178},"content/sk/pages/home.json","Domov",{"id":96,"title":94,"carousel":97,"sections":124},"index",{"autoplayInterval":98,"slides":99},0,[100,105,109,114,119],{"photo":101,"title":102,"description":103,"link":104},"home/carousel/accommodation.jpg","Ubytovanie","Penzión Turzov sa nachádza v rekreačnej lokalite Turzov, približne 2 km od centra mesta Gelnica a len na skok od areálu bývalých Turzovských kúpeľov. Penzión sa nachádza pri spodnom Turzovskom jazere, obklopený čarokrásnou prírodou, ktorá ponúka nespočetné možnosti pre relax, rekreačnú turistiku ale aj pre náročnejších turistov. Návštevníkom je penzión k dispozícii celoročne.",{"text":102,"page":9},{"photo":106,"title":24,"description":107,"link":108},"home/carousel/restaurant.jpg","Penzión Turzov disponuje reštauračnou časťou, kde sa návštevníci môžu občerstviť a vychutnať si výborné pivo, lahodnú kávu či vybrať si z ponuky hotových jedál. V prípade priaznivého počasia je tiež k dispozícii na sedenie aj terasa. V tesnej blízkosti penziónu sa nachádza niekoľko altánkov a ohnísk vhodných na opekanie.",{"text":24,"page":10},{"photo":110,"title":111,"description":112,"link":113},"home/carousel/terrace.jpg","Terasa a požičovňa","Počas letnej sezóny tiež prevádzkujeme pre návštevníkov pri hornom turzovskom jazere bufet s občerstvením (približne 10 min.od penziónu), kde v sezóne roku 2024 pribudla aj možnosť zapožičať si lehátka, paddleboardy a ďalšie športové vybavenie.",{"text":111,"page":11},{"photo":115,"title":116,"description":117,"link":118},"home/carousel/tips.jpg","Tipy na výlety","Návštevníci si v rámci oddychu môžu vychutnať pohľad na nádhernú okolitú prírodu alebo navštíviť neďaleký Banský skanzen a Štôlňu Jozef. Okolie poskytuje nemálo možností na nenáročné aj dlhšie a náročnejšie vychádzky a cyklotúry. Okolité tajchy tiež vytvárajú vhodné podmienky pre nadšencov rybolovu. ",{"text":116,"page":12},{"photo":28,"title":120,"description":121,"link":122},"TurzoVia","V lete 2025 pribudne v bezprostrednej blízkosti penziónu unikátna lanová dráha TurzoVia. Lanový park s celkovou dĺžkou viac ako 110m umiestnený na živých stromoch poskytne nezabudnuteľné adrenalínové zážitky pre malých aj veľkých.",{"text":120,"page":123},"turzovia",[125,129,132,136,141],{"title":102,"description":26,"link":126,"photos":127},{"text":102,"page":9},[128,128,128],"https://rnb.scene7.com/is/image/roomandboard/HCC_bedroom_01_0425?size=2400,2400&scl=1",{"title":24,"description":26,"link":130,"photos":131},{"text":24,"page":10},[28,28,28],{"title":111,"description":26,"link":133,"photos":134},{"text":111,"page":11},[135,135,135],"https://static.vecteezy.com/system/resources/previews/011/236/240/non_2x/on-a-lake-in-sweden-in-smalland-water-lily-field-blue-water-sunny-sky-forests-photo.jpg",{"title":137,"description":26,"link":138,"photos":139},"Tipy na výlet",{"text":137,"page":12},[140,140,140],"https://images.photowall.com/products/73393/perfect-beach.jpg?h=699&q=85",{"title":142,"description":26,"link":143,"photos":144},"Turzovia",{"text":142,"page":123},[145,145,145],"https://slovenskycestovatel.sk/images/items/1693/tarzania-kubinska-hola96102524.jpg",{"carousel":147,"sections":159},{"autoplayInterval":98,"slides":148},[149,151,153,155,157],{"photo":101,"title":102,"description":103,"link":150},{"text":102,"page":9},{"photo":106,"title":24,"description":107,"link":152},{"text":24,"page":10},{"photo":110,"title":111,"description":112,"link":154},{"text":111,"page":11},{"photo":115,"title":116,"description":117,"link":156},{"text":116,"page":12},{"photo":28,"title":120,"description":121,"link":158},{"text":120,"page":123},[160,163,166,169,172],{"title":102,"description":26,"link":161,"photos":162},{"text":102,"page":9},[128,128,128],{"title":24,"description":26,"link":164,"photos":165},{"text":24,"page":10},[28,28,28],{"title":111,"description":26,"link":167,"photos":168},{"text":111,"page":11},[135,135,135],{"title":137,"description":26,"link":170,"photos":171},{"text":137,"page":12},[140,140,140],{"title":142,"description":26,"link":173,"photos":174},{"text":142,"page":123},[145,145,145],"/sk/pages/home",{"title":94},"sk/pages/home","Q9_2iV6dj32FTgQyIMfRdWKg7ZatkVyLsWWmzNwTG64",{"id":180,"title":102,"body":181,"description":13,"extension":14,"meta":230,"navigation":17,"path":244,"seo":245,"stem":246,"__hash__":247},"content/sk/pages/accommodation.json",{"id":9,"title":102,"rooms":182},[183,199,213],{"name":184,"description":185,"price":186,"bookingLink":189,"photos":192},"Izba Economy #1","Izba so zariadením na osobnú hygienu (WC, umývadlo, sprchový kút) a balkónom. Izba je vybavená posteľami, nočnými stolíkmi s nočnými lampami, skriňou s ramienkami, komodou a televízorom. Súčasťou izby je tiež chladnička, varná kanvica, šálky, tanieriky, príbor a nádoba na odpadky. V prípade potreby je izbu možné dovybaviť prístelkou alebo detskou postieľkou v cene 15€/noc.",{"onePerson":187,"twoPersons":188},"35","55",{"text":190,"url":191},"Booking","https://www.booking.com/hotel/sk/penzion-turzov-gelnica.sk.html?label=gen173nr-1BCAEoggI46AdIM1gEaM0BiAEBmAEiuAEXyAEM2AEB6AEBiAIBqAIDuAKX_L7ABsACAdICJDAwNmE4ODA2LWY4OGEtNDFmMy1hYTQyLWM1YTlkNGQ4Y2YwMdgCBeACAQ&sid=bd1edb9bf1a9487e235fd063450aec0a&aid=304142&ucfs=1&arphpl=1",[193,194,195,196,197,198],"accommodation/Izba_1_1-min.jpg","accommodation/Izba_1_3-min.jpg","accommodation/Izba_1_5-min.jpg","accommodation/kupelna_1_1-min.jpg","accommodation/kupelna_1_2-min.jpg","accommodation/kupelna_1_3-min.jpg",{"name":200,"description":201,"price":202,"bookingLink":203,"photos":204},"Izba Economy #2","Izba so zariadením na osobnú hygienu (WC, umývadlo, sprchový kút) a balkónom. Izba je vybavená manželskou posteľou, nočnými stolíkmi s nočnými lampami, skriňou s ramienkami, komodou a televízorom. Súčasťou izby je tiež chladnička, varná kanvica, šálky, tanieriky, príbor a nádoba na odpadky. V prípade potreby je izbu možné dovybaviť prístelkou alebo detskou postieľkou v cene 15€/noc.",{"onePerson":187,"twoPersons":188},{"text":190,"url":191},[205,206,207,208,209,210,211,212],"accommodation/Izba_2_1-min.jpg","accommodation/Izba_2_2-min.jpg","accommodation/Izba_2_4-min.jpg","accommodation/Izba_2_5-min.jpg","accommodation/kupelna_2_1-min.jpg","accommodation/kupelna_2_2-min.jpg","accommodation/kupelna_2_4-min.jpg","accommodation/kupelna_2_5-min.jpg",{"name":214,"description":215,"price":216,"bookingLink":219,"photos":220},"Izba DeLuxe","Izba s predsieňou a zariadením na osobnú hygienu (WC, umývadlo, sprchový kút) a balkónom. Izba je priestrannejšia, vybavená manželskou posteľou, rozkladacím gaučom, nočnými stolíkmi s nočnými lampami, konferenčným stolíkom, stolom so stoličkami, skriňou s ramienkami, komodou a televízorom. Súčasťou izby je aj stôl so stoličkami, chladnička, varná kanvica, šálky, taniere, príbory a nádoba na odpadky. V prípade potreby je izbu možné dovybaviť prístelkou alebo detskou postieľkou v cene 15€/noc.",{"onePerson":217,"twoPersons":218},"60","70",{"text":190,"url":191},[221,222,223,224,225,226,227,228,229],"accommodation/Izba_3_1-min.jpg","accommodation/Izba_3_2-min.jpg","accommodation/Izba_3_3-min.jpg","accommodation/Izba_3_4-min.jpg","accommodation/Izba_3_6-min.jpg","accommodation/Izba_3_7-min.jpg","accommodation/kupelna_3_1-min.jpg","accommodation/kupelna_3_2-min.jpg","accommodation/kupelna_3_3-min.jpg",{"rooms":231},[232,236,240],{"name":184,"description":185,"price":233,"bookingLink":234,"photos":235},{"onePerson":187,"twoPersons":188},{"text":190,"url":191},[193,194,195,196,197,198],{"name":200,"description":201,"price":237,"bookingLink":238,"photos":239},{"onePerson":187,"twoPersons":188},{"text":190,"url":191},[205,206,207,208,209,210,211,212],{"name":214,"description":215,"price":241,"bookingLink":242,"photos":243},{"onePerson":217,"twoPersons":218},{"text":190,"url":191},[221,222,223,224,225,226,227,228,229],"/sk/pages/accommodation",{"title":102},"sk/pages/accommodation","Xf6w3CpVWwOVcQ3jaGuDaxSis8Y9CRqy4BBuyrz5IvQ",{"id":23,"title":24,"body":249,"description":26,"extension":14,"meta":260,"navigation":17,"path":67,"seo":271,"stem":69,"__hash__":70},{"id":10,"title":24,"description":26,"photos":250,"openingHoursTitle":29,"openingHours":251,"menuTitle":46,"menu":259},[28,28,28],[252,253,254,255,256,257,258],{"day":32,"fromTo":33},{"day":35,"fromTo":33},{"day":37,"fromTo":33},{"day":39,"fromTo":33},{"day":41,"fromTo":33},{"day":43,"fromTo":33},{"day":45,"fromTo":33},[48,49,50,51,52,53,54,55],{"photos":261,"openingHoursTitle":29,"openingHours":262,"menuTitle":46,"menu":270},[28,28,28],[263,264,265,266,267,268,269],{"day":32,"fromTo":33},{"day":35,"fromTo":33},{"day":37,"fromTo":33},{"day":39,"fromTo":33},{"day":41,"fromTo":33},{"day":43,"fromTo":33},{"day":45,"fromTo":33},[48,49,50,51,52,53,54,55],{"title":24,"description":26},{"id":273,"title":111,"body":274,"description":26,"extension":14,"meta":301,"navigation":17,"path":317,"se